<%- include('partials/header') %>

<!-- HERO -->
<div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
        <span class="hero-eyebrow">Eco-Adventure Wildlife Park</span>
        <h1>Where the Wild<br>World Awaits</h1>
        <p>Five breathtaking habitats. Unforgettable wildlife encounters.<br>Adventure at every turn.</p>
        <div class="hero-buttons">
            <a href="/habitats" class="btn">Explore Habitats</a>
            <a href="/activities" class="btn-outline">See Activities</a>
        </div>
    </div>
</div>

<!-- STATS STRIP -->
<div class="stats-strip">
    <div class="stat-item">
        <span class="stat-number">5</span>
        <span class="stat-label">Unique Habitats</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
        <span class="stat-number">15+</span>
        <span class="stat-label">Wildlife Experiences</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
        <span class="stat-number">100+</span>
        <span class="stat-label">Animal Species</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
        <span class="stat-number">9–6</span>
        <span class="stat-label">Open Every Day</span>
    </div>
</div>

<!-- OPENING TIMES -->
<div class="opening-times-banner">
    <div class="opening-times-inner">
        <span class="opening-icon">&#128338;</span>
        <div>
            <strong>Open Every Day of the Year</strong>
            <span>9:00 AM &ndash; 6:00 PM &nbsp;&nbsp;|&nbsp;&nbsp; Last entry 5:00 PM</span>
            <span class="opening-note">Including Bank Holidays &amp; Weekends</span>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="search-section">
    <h2>Find Your Adventure</h2>
    <p class="search-subtitle">Search across all habitats and wildlife experiences</p>
    <div class="search-container">
        <input type="text" id="searchInput"
               placeholder="Try &quot;lions&quot;, &quot;rainforest&quot; or &quot;night safari&quot;..."
               aria-label="Search habitats and experiences">
    </div>
    <div id="searchResults"></div>
</div>

<!-- HABITATS -->
<section class="home-section">
    <div class="gold-rule"><h2>Explore Our Five Habitats</h2></div>
    <p class="section-subtitle">Each habitat is a world unto itself — immersive, authentic, and unforgettable</p>
    <div class="habitat-grid">
        <div class="habitat-card">
            <div class="habitat-card-img-wrap">
                <img src="/images/rainforest_retreat.jpg" alt="Rainforest Retreat">
                <div class="habitat-card-overlay">
                    <span>3 Experiences</span>
                </div>
            </div>
            <div class="habitat-card-body">
                <h3>Rainforest Retreat</h3>
                <p>Immerse yourself in a lush, vibrant world of exotic birds, colourful frogs and towering ancient trees.</p>
                <a href="/habitat/1" class="btn">Discover &rarr;</a>
            </div>
        </div>
        <div class="habitat-card">
            <div class="habitat-card-img-wrap">
                <img src="/images/habitat_savannah.jpg" alt="Savannah Plains">
                <div class="habitat-card-overlay">
                    <span>3 Experiences</span>
                </div>
            </div>
            <div class="habitat-card-body">
                <h3>Savannah Plains</h3>
                <p>Spot majestic lions, towering giraffes and playful zebras roaming freely across the golden plains.</p>
                <a href="/habitat/2" class="btn">Discover &rarr;</a>
            </div>
        </div>
        <div class="habitat-card">
            <div class="habitat-card-img-wrap">
                <img src="/images/arctic_discovery_zone.jpg" alt="Arctic Discovery Zone">
                <div class="habitat-card-overlay">
                    <span>3 Experiences</span>
                </div>
            </div>
            <div class="habitat-card-body">
                <h3>Arctic Discovery Zone</h3>
                <p>Journey to the frozen north and come face to face with polar bears and arctic foxes in their icy home.</p>
                <a href="/habitat/3" class="btn">Discover &rarr;</a>
            </div>
        </div>
        <div class="habitat-card">
            <div class="habitat-card-img-wrap">
                <img src="/images/mystic_marshlands.jpg" alt="Mystic Marshlands">
                <div class="habitat-card-overlay">
                    <span>3 Experiences</span>
                </div>
            </div>
            <div class="habitat-card-body">
                <h3>Mystic Marshlands</h3>
                <p>Explore eerie, beautiful wetlands filled with rare amphibians, water birds and hidden lagoons.</p>
                <a href="/habitat/4" class="btn">Discover &rarr;</a>
            </div>
        </div>
        <div class="habitat-card">
            <div class="habitat-card-img-wrap">
                <img src="/images/nightglow_forest.jpg" alt="Nightglow Forest">
                <div class="habitat-card-overlay">
                    <span>3 Experiences</span>
                </div>
            </div>
            <div class="habitat-card-body">
                <h3>Nightglow Forest</h3>
                <p>Enter a magical forest that comes alive after dark — glowing creatures, bats, owls and more await.</p>
                <a href="/habitat/5" class="btn">Discover &rarr;</a>
            </div>
        </div>
    </div>
</section>

<!-- WHY VISIT -->
<section class="why-section">
    <div class="gold-rule"><h2>Why Visit Wild Nature?</h2></div>
    <div class="why-grid">
        <div class="why-card">
            <div class="why-icon">&#127807;</div>
            <h3>Conservation First</h3>
            <p>Every visit supports our global wildlife conservation programmes and habitat protection efforts.</p>
        </div>
        <div class="why-card">
            <div class="why-icon">&#128249;</div>
            <h3>Unforgettable Encounters</h3>
            <p>Get closer than you ever imagined — from hand-feeding giraffes to watching polar bears swim.</p>
        </div>
        <div class="why-card">
            <div class="why-icon">&#127968;</div>
            <h3>Five Worlds in One Day</h3>
            <p>Walk from a tropical rainforest to the frozen Arctic and everything in between, all in one visit.</p>
        </div>
        <div class="why-card">
            <div class="why-icon">&#128106;</div>
            <h3>Perfect for All Ages</h3>
            <p>From toddlers to grandparents — Wild Nature is designed for every kind of explorer.</p>
        </div>
    </div>
</section>

<!-- CTA BANNER -->
<div class="cta-banner">
    <div class="cta-content">
        <h2>Ready for Your Wild Adventure?</h2>
        <p>Discover all 15+ experiences across our five incredible habitats</p>
        <a href="/activities" class="btn">See All Activities</a>
        <a href="/contact" class="btn-outline">Get in Touch</a>
    </div>
</div>

<script src="/js/ajax-search.js"></script>
<%- include('partials/footer') %>