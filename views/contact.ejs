<%- include('partials/header') %>

<h1>Contact Us</h1>
<p>Have a question? Send us a message and we'll get back to you within 48 hours.</p>

<form class="contact-form" id="contactForm" action="/contact" method="POST">
    <div class="form-group">
        <label for="name">Name *</label>
        <input type="text" id="name" name="name" required>
        <div class="error-message" id="nameError">Please enter your name</div>
    </div>

    <div class="form-group">
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required>
        <div class="error-message" id="emailError">Please enter a valid email address</div>
    </div>

    <div class="form-group">
        <label for="message">Message *</label>
        <textarea id="message" name="message" rows="5" required></textarea>
        <div class="error-message" id="messageError">Please enter your message</div>
    </div>

    <button type="submit" class="submit-btn">Send Message</button>
</form>

<script src="/js/contact-validation.js"></script>

<%- include('partials/footer') %>
