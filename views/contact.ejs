<%- include('partials/header') %>

<div class="page-hero">
    <div class="page-hero-text">
        <span class="hero-eyebrow">Get in Touch</span>
        <h1>Contact Us</h1>
        <p>Have a question about your visit? Want to know about group bookings or special events?
           Our team will get back to you within 48 hours.</p>
    </div>
</div>

<div class="contact-layout">
    <div class="contact-info">
        <h2>Visit Information</h2>

        <div class="contact-info-item">
            <span class="contact-icon">&#128205;</span>
            <div>
                <strong>Location</strong>
                <span>Wild Nature Park, Heart of the Countryside, United Kingdom</span>
            </div>
        </div>

        <div class="contact-info-item">
            <span class="contact-icon">&#128337;</span>
            <div>
                <strong>Opening Hours</strong>
                <span>Every day: 9:00 AM – 6:00 PM</span>
                <span style="font-size:0.8rem; color:#B8A898;">Last entry at 5:00 PM</span>
            </div>
        </div>

        <div class="contact-info-item">
            <span class="contact-icon">&#128231;</span>
            <div>
                <strong>Email</strong>
                <span>info@wildnaturepark.co.uk</span>
            </div>
        </div>

        <div class="contact-info-item">
            <span class="contact-icon">&#128222;</span>
            <div>
                <strong>Phone</strong>
                <span>+44 (0) 1234 567 890</span>
            </div>
        </div>

        <div class="contact-notice">
            <p>&#9432; We aim to respond to all enquiries within <strong>48 hours</strong> during business days.</p>
        </div>
    </div>

    <form class="contact-form" id="contactForm" novalidate>
        <h2>Send a Message</h2>

        <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="e.g. Jane Smith" required>
            <div class="error-message" id="nameError">Please enter your name</div>
        </div>

        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="e.g. jane@example.com" required>
            <div class="error-message" id="emailError">Please enter a valid email address</div>
        </div>

        <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" rows="6"
                      placeholder="How can we help? Ask about group visits, accessibility, events..." required></textarea>
            <div class="error-message" id="messageError">Please enter your message</div>
        </div>

        <button type="submit" class="submit-btn">Send Message &rarr;</button>
    </form>
</div>

<div id="successMessage" style="display:none;">
    <div class="success-container">
        <div class="success-card">
            <span class="success-icon">&#10003;</span>
            <h1>Message Sent!</h1>
            <p>Thank you for contacting Wild Nature Park.</p>
            <p>We'll reply within 48 hours.</p>
            <a href="/" class="btn">Return Home</a>
        </div>
    </div>
</div>

<script src="/js/contact-validation.js"></script>
<%- include('partials/footer') %>