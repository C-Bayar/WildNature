<%- include('partials/header') %>

<div class="activity-hero">
    <div class="activity-hero-bg"></div>
    <div class="activity-hero-content">
        <span class="hero-eyebrow">Get Involved</span>
        <h1>Adventure Activities</h1>
        <p>From treetop walks to night safaris — there's something to thrill every explorer</p>
    </div>
</div>

<div class="filter-section">
    <span class="filter-label">Filter by Habitat:</span>
    <button class="filter-btn active" data-filter="all">All Habitats</button>
    <% const habitatNames = [...new Set(experiences.map(e => e.habitat_name))]; %>
    <% habitatNames.forEach(name => { %>
        <button class="filter-btn" data-filter="<%= name %>"><%= name %></button>
    <% }); %>
</div>

<div class="activity-grid" id="activityGrid">
    <% experiences.forEach(exp => { %>
        <div class="activity-card" data-habitat="<%= exp.habitat_name %>">
            <div class="activity-img-wrap">
                <img src="<%= exp.image_url %>" alt="<%= exp.name %>"
                     onerror="this.src='https://placehold.co/400x220/2A2A26/E8900A?text=<%= encodeURIComponent(exp.name) %>'">
            </div>
            <div class="activity-info">
                <div class="activity-meta">
                    <span class="habitat-tag"><%= exp.habitat_name %></span>
                    <span>&#128337; 30–45 mins</span>
                </div>
                <h2><%= exp.name %></h2>
                <p><%= exp.description %></p>
                <a href="/experience/<%= exp.id %>" class="book-btn">Find Out More &rarr;</a>
            </div>
        </div>
    <% }); %>
</div>

<script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const filter = btn.dataset.filter;
            document.querySelectorAll('.activity-card').forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.habitat === filter) ? 'block' : 'none';
            });
        });
    });
</script>

<%- include('partials/footer') %>