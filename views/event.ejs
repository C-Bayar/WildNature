<%- include('partials/header') %>

<a href="/events" class="back-link">&larr; All Events</a>

<div class="event-detail">
    <img src="<%= event.image_url || '/images/night_safari.jpg' %>" alt="<%= event.title %>"
         onerror="this.src='https://placehold.co/1200x400/2A2A26/E8900A?text=Event'">

    <div class="event-content">
        <span class="status-badge status-<%= event.status %>">
            <% if (event.status === 'upcoming') { %>&#128338; Upcoming Event<% } %>
            <% if (event.status === 'today') { %>&#11088; Happening Today!<% } %>
            <% if (event.status === 'past') { %>&#10003; Past Event<% } %>
        </span>

        <div class="gold-rule"><h1><%= event.title %></h1></div>

        <div class="event-meta">
            <div class="event-meta-item">
                <span class="meta-icon">&#128197;</span>
                <div>
                    <strong>Date</strong>
                    <span><%= new Date(event.event_date).toLocaleDateString('en-GB', {
                        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                    }) %></span>
                </div>
            </div>
            <div class="event-meta-item">
                <span class="meta-icon">&#128204;</span>
                <div>
                    <strong>Category</strong>
                    <span><%= event.category %></span>
                </div>
            </div>
            <div class="event-meta-item">
                <span class="meta-icon">&#128337;</span>
                <div>
                    <strong>Time</strong>
                    <span>10:00 AM – 4:00 PM</span>
                </div>
            </div>
            <div class="event-meta-item">
                <span class="meta-icon">&#128205;</span>
                <div>
                    <strong>Location</strong>
                    <span>Wild Nature Park</span>
                </div>
            </div>
        </div>

        <div class="event-description">
            <h2>About This Event</h2>
            <p><%= event.description %></p>
        </div>

        <% if (event.status === 'past') { %>
            <div class="past-event-notice">
                <span>&#9888;</span> This event has already taken place. Check our
                <a href="/events">upcoming events</a> for what's next.
            </div>
        <% } %>

        <div class="event-actions">
            <% if (event.status === 'upcoming') { %>
                <a href="/contact" class="btn">Enquire About This Event &rarr;</a>
            <% } %>
            <a href="/events" class="btn-outline">&larr; Back to Events</a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>