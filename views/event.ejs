<%- include('partials/header') %>

<div class="event-detail">
    <img src="<%= event.image_url || '/images/event_default.jpg' %>" alt="<%= event.title %>" onerror="this.src='https://placehold.co/800x400/2e7d32/white?text=Event'">
    
    <div class="event-content">
        <span class="status-badge status-<%= event.status %>">
            <% if (event.status === 'upcoming') { %>Upcoming Event<% } %>
            <% if (event.status === 'today') { %>Happening Today! <% } %>
            <% if (event.status === 'past') { %>Past Event<% } %>
        </span>
        
        <h1><%= event.title %></h1>
        
        <div class="event-meta">
            <p><strong> Date:</strong> <%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <p><strong> Category:</strong> <%= event.category %></p>
            <p><strong> Time:</strong> 10:00 AM - 4:00 PM</p>
            <p><strong> Location:</strong> WildNature Park</p>
        </div>
        
        <h2>About This Event</h2>
        <p style="font-size: 1.1rem; line-height: 1.6;"><%= event.description %></p>
        
        <% if (event.status === 'upcoming') { %>
            <a href="/contact" class="btn" style="display: inline-block; margin-top: 1rem;">Book Your Place →</a>
        <% } %>
        
        <a href="/events" class="btn" style="display: inline-block; margin-top: 1rem; margin-left: 1rem; background: #666;">← Back to Events</a>
    </div>
</div>

<%- include('partials/footer') %>